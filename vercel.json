{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/(about|admin|index|map|news-write|property-news|news-detail)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "redirects": [
    { "source": "/news", "destination": "/property-news?v=20260715_v31", "permanent": false },
    { "source": "/news.html", "destination": "/property-news?v=20260715_v31", "permanent": false }
  ],
  "rewrites": [
    { "source": "/rss", "destination": "/api/rss" },
    { "source": "/rss.xml", "destination": "/api/rss" },
    { "source": "/sitemap", "destination": "/api/sitemap" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/news-detail", "destination": "/api/news-detail" },
    { "source": "/news-detail.html", "destination": "/api/news-detail" }
  ]
}
